{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://subhoptionlab.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://subhoptionlab.onrender.com/ws/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}